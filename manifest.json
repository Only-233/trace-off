{
  "manifest_version": 3,
  "name": "止痕 Trace Off",
  "version": "1.0.0",
  "description": "按域名禁止浏览器保存历史记录",
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "permissions": ["history", "storage", "tabs", "activeTab"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "止痕 Trace Off",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "options_page": "options/options.html"
}
